# Jira Test Data Generator - Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit the .env file to git!

# Required: Your Jira API token
# Get it from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_api_token_here

# Optional: Set defaults to avoid typing them every time
# JIRA_URL=https://rewind.atlassian.net
# JIRA_EMAIL=your.email@rewind.com
# JIRA_PROJECT=TEST
